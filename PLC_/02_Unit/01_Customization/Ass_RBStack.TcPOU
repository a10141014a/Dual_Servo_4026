<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Ass_RBStack" Id="{ecfcfd77-7c6f-4850-832d-5d24c8fb40fb}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Ass_RBStack IMPLEMENTS ITF_AutoStructCommand
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	strText	:STRING;
	i,_CaptureStep	:INT;
	_bProcessScan,_bInitialScan: BOOL;
	_bHalt , _bError,_bHaltPause: BOOL;
	nStep,nInitiStep ,nNGStep,nShackStep,nPalletStep	: INT;
	_tmrT0,_tmrT1,tmrshock	,tmrNG,tmrPalletTime,tmrAutoPass,tmrStarRetry		:TON;
	bBoxPass: BOOL;
	nNextStep: INT;
	rPalletInPos	:Tc2_Standard.R_TRIG;
	PalletNumb,PalletSensorNumb,Palletslot			:INT;
	bAutoPass: BOOL;
	wRetry:INT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT _bInitialScan THEN
	nInitiStep	:= 0;
END_IF

_bInitialScan:=FALSE;



IF NOT _bProcessScan THEN
	nNextStep	:= 0;
	nStep		:= 0;
END_IF

_bProcessScan	:=FALSE;

//
rPalletInPos(CLK:= RB_KR_StackingIO.fb_bPalletInPos);
IF rPalletInPos.Q THEN
	PalletSensorNumb:= PalletSensorNumb + 1;
END_IF

CASE nPalletStep OF
	0://
		IF RB_KR_StackingIO.fb_bPalletInPos THEN
			Palletslot	:= 0;
			RB_KR_StackingIO.cmd_wLayer_No	:= INT_TO_BYTE(RunParameter.StackingRB_LayerData[0]);
			PalletNumb	:= PalletSensorNumb	;
			nPalletStep:= 5;
		END_IF

	5://
		Hmi_bChangePalletDemand	:= FALSE;
		RB_KR_StackingIO.cmd_bPallet_AllowPut	:= RB_KR_StackingIO.fb_bPalletInPos ;
				
		IF  RB_KR_StackingIO.fb_bPalletFinish THEN
			DoNotLoadingRB	:= TRUE;
			nPalletStep:= 10;
			RB_KR_StackingIO.cmd_bPallet_AllowPut	:= FALSE;
			PalletNumb	:= PalletSensorNumb	;
			Counter_Pallet	:= Counter_Pallet + 1;
			Palletslot		:= Palletslot + 1;
			//check pallet Safe
			IF RunParameter.StackingRB_LayerData[Palletslot] =0 THEN
				Palletslot	:= 0;
			END_IF
		END_IF
	10:

		RB_KR_StackingIO.cmd_bCount0	:= TRUE;
		IF RB_KR_StackingIO.fb_wPartNo = 1 AND NOT RB_KR_StackingIO.fb_bPalletFinish THEN
			RB_KR_StackingIO.cmd_bCount0	:= FALSE;
			nPalletStep:= 15;
		END_IF	
	15://偵測換版 
		
		Hmi_bChangePalletDemand	:= TRUE;
		IF Hmi_bAutoChangePallet THEN
			tmrPalletTime(IN:= RB_KR_StackingIO.fb_bPalletInPos AND PalletNumb <> PalletSensorNumb );
			IF tmrPalletTime.Q THEN
				PalletNumb	:= PalletSensorNumb	;
				RB_KR_StackingIO.cmd_wLayer_No	:= INT_TO_BYTE(RunParameter.StackingRB_LayerData[Palletslot]);
				nPalletStep:= 5;
			END_IF
		END_IF
		IF Hmi_bChangePalletbtn THEN
			PalletNumb	:= PalletSensorNumb	;
			RB_KR_StackingIO.cmd_wLayer_No	:= INT_TO_BYTE(RunParameter.StackingRB_LayerData[Palletslot]);
			nPalletStep:= 5;			
			Hmi_bChangePalletbtn:=FALSE;
		END_IF

END_CASE






]]></ST>
    </Implementation>
