    <Method Name="Initialization" Id="{5bdb1a4e-0f0d-4fa0-86f0-2e4bd277a615}">
      <Declaration><![CDATA[METHOD Initialization : BOOL
VAR_INPUT
	_Testmode	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bInitialScan:=TRUE;

CASE nInitiStep OF
	0:		
		strText					:= 'ORG : Inital';
		Cyl_ExitStopper.qExtendCoil	:=FALSE;
		Cyl_ExitClip.qExtendCoil	:=FALSE;
		Roller_Exit.qRun			:=FALSE;	
		nInitiStep				:= 5;	
	5:
		IF 	NOT Sen_ExitLoadIn AND NOT Sen_ExitBoxCheck AND NOT Sen_ExitComvStop THEN
			nInitiStep				:= 10;	
		END_IF;
	10:
			strText:='ORG : Done ';
			Initialization	:= TRUE;
	
END_CASE;]]></ST>
      </Implementation>
    </Method>
