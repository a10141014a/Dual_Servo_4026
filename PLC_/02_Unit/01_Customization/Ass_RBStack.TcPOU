    <Method Name="Process" Id="{661e149b-7f8e-4e97-bfdc-f58e8340293f}">
      <Declaration><![CDATA[METHOD Process : BOOL
VAR_INPUT
	bHlatMode	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bProcessScan:=TRUE;


CASE nStep OF
	0:
		_tmrT0(IN:=FALSE);
		_tmrT1(IN:=FALSE);
		_CaptureStep				:= 0;
		Roller_Exit.qRun			:= TRUE;
		Cyl_ExitStopper.qExtendCoil	:=FALSE;
		IF Sen_ExitLoadIn THEN
			nStep	:= 5;
		END_IF
		IF bAutoPass	THEN
			nStep	:= 11;
		END_IF
		
	5:
		_tmrT0(IN:=Sen_ExitBoxCheck,PT:=T#0.2S);
		IF _tmrT0.Q THEN
			Cyl_ExitStopper.qExtendCoil:=	TRUE;
			_tmrT0(IN:=FALSE);
			Roller_Exit.qRun			:= FALSE;
			Cyl_ExitClip.qExtendCoil	:= TRUE;
			nStep	:= 10;
		END_IF
	10:
		_tmrT0(IN:=TRUE,PT:=T#0.2S);	
		_tmrT1(IN:=Sen_ExitComvStop,PT:=T#0.2S);		
		IF _tmrT0.Q THEN
			IF _tmrT1.q THEN
				_tmrT0(IN:=FALSE);
				_tmrT1(IN:=FALSE);
				Cyl_ExitClip.qExtendCoil	:= FALSE;
				nStep	:= 15;
			END_IF;		
		END_IF
	11:
		tmrAutoPass(IN:= TRUE,PT:=T#2S);
		IF tmrAutoPass.Q THEN
			tmrAutoPass(IN:= FALSE);
			nStep	:= 15;
		END_IF
	15://通知手臂
		tmrStarRetry(IN:=NOT tmrStarRetry.Q  ,PT:=T#0.5S);
		IF tmrStarRetry.Q THEN
			IF RB_KR_SysIO.iEXT_CONTROL AND NOT DoNotLoadingRB THEN
				IF RB_KR_SysIO.iPGNO_REQ THEN
					tmrStarRetry.IN := TRUE;
					RB_KR_SysIO.qEXT_START:= TRUE;
				END_IF
				IF NOT RB_KR_SysIO.iPGNO_REQ AND NOT RB_KR_SysIO.iRobotRunning THEN
					tmrStarRetry.IN 	:= TRUE;
					RB_KR_SysIO.qEXT_START:= TRUE;
				END_IF		
			END_IF;	
		END_IF
		

		
		CASE _CaptureStep OF	
		0:
			RB_KR_StackingIO.cmd_bPartInPos	:= TRUE;
			_CaptureStep	:= 5;
			
		5:
			IF RB_KR_StackingIO.fb_bPickFinish THEN
				RB_KR_StackingIO.cmd_bPartInPos	:= FALSE;
				_CaptureStep	:= 10;
			END_IF
	
		10:
			IF NOT RB_KR_StackingIO.fb_bPickFinish THEN
				_CaptureStep	:= 15;
			END_IF		
		15:
			_CaptureStep	:= 0;
			nStep			:= 20;
		END_CASE;	

		
	20:
		
		IF NOT Sen_ExitLoadIn AND NOT Sen_ExitBoxCheck AND NOT Sen_ExitComvStop THEN
			nStep	:= 0;
		END_IF
	
	
	
	

END_CASE]]></ST>
      </Implementation>
    </Method>
