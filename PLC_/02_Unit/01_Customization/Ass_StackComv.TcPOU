    <Method Name="Process" Id="{6448f121-61fb-4edd-a9d3-84894ee57953}">
      <Declaration><![CDATA[METHOD Process : BOOL
VAR_INPUT
	bHlatMode	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bProcessScan	:= TRUE;
CASE nStep OF 
	0:
		Vacm_StackUD			:=FALSE;
		Cyl_StackUD.qExtendCoil	:=FALSE;
		Motor_Stack.qRun		:=TRUE;
		nStep					:= 5;
		_tmrT0(IN:=FALSE);
		_tmrT1(IN:=FALSE);
	5:
		IF RunParameter.stack_bUsed THEN
				IF Sen_StackComvStop THEN
					Motor_Stack.qRun		:=FALSE;
					nStep					:= 9;
				END_IF
			ELSE		
		
			;
		
		
		END_IF
	9:
		_tmrT0(IN:=TRUE,PT:=T#1S);
		IF _tmrT0.Q THEN
			_tmrT0(IN:=FALSE);
			nStep					:= 10;
		END_IF		
		
	10://堆疊1
		Cyl_StackUD.qExtendCoil	:= TRUE;
		_tmrT0(IN:=TRUE,PT:=RunParameter.stack_DelayTime1);
		IF _tmrT0.Q THEN
			_tmrT0(IN:=FALSE);
			nStep					:= 15;
		END_IF
	15:
		Vacm_StackUD			:=TRUE;	
		_tmrT0(IN:=TRUE,PT:=T#1S);
		IF _tmrT0.Q THEN
			_tmrT0(IN:=FALSE);
			nStep					:= 20;
		END_IF
	20:
		Cyl_StackUD.qExtendCoil	:= FALSE;		
		IF Cyl_StackUD.iOriginSensor THEN
			nStep					:= 25;
		END_IF		
	25:
		Motor_Stack.qRun		:=TRUE;
		IF Sen_StackComvStop THEN
			Motor_Stack.qRun		:=FALSE;
			nStep					:= 30;
		END_IF	
	30:	
		_tmrT0(IN:=TRUE,PT:=T#1S);
		IF _tmrT0.Q THEN
			_tmrT0(IN:=FALSE);
			nStep					:= 35;
		END_IF		
	
	35:		
		Cyl_StackUD.qExtendCoil	:= TRUE;
		_tmrT0(IN:=TRUE,PT:=RunParameter.stack_DelayTime2);
		IF _tmrT0.Q THEN
			_tmrT0(IN:=FALSE);
			nStep					:= 40;
		END_IF		
	40:
		Cyl_StackUD.qExtendCoil	:= FALSE;
		Vacm_StackUD			:=FALSE;
		_tmrT0(IN:=TRUE,PT:=T#0.5S);
		IF _tmrT0.Q THEN
			_tmrT0(IN:=FALSE);
			nStep					:= 45;
		END_IF						
	45:
		Motor_Stack.qRun		:=TRUE;
		IF NOT Sen_StackComvStop THEN
			nStep					:=0;
		END_IF	
	
	
	
	
END_CASE]]></ST>
      </Implementation>
    </Method>
