  <POU Name="Ass_StackComv" Id="{4b25830c-f5af-4eac-9d4d-de80b24edd39}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Ass_StackComv IMPLEMENTS ITF_AutoStructCommand
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	strText	:STRING;
	i	:INT;
	_bProcessScan,_bInitialScan: BOOL;
	_bHalt , _bError,_bHaltPause: BOOL;
	nStep,nInitiStep  	: INT;
	_tmrT0,_tmrT1		:TON;
	bBoxPass: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT _bInitialScan THEN
	nInitiStep	:= 0;
END_IF

_bInitialScan:=FALSE;



IF NOT _bProcessScan THEN
	nStep	:= 0;
END_IF

_bProcessScan:=FALSE;]]></ST>
    </Implementation>
