    <Method Name="Initialization" Id="{68df2561-95fa-4481-b660-382046a2754b}">
      <Declaration><![CDATA[METHOD Initialization : BOOL
VAR_INPUT
	_Testmode	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bInitialScan:=TRUE;

CASE nInitiStep OF
	0:		
		strText					:= 'ORG : Inital';
		Motor_Stack.qRun		:=FALSE;
		Vacm_StackUD			:=FALSE;
		Cyl_StackUD.qExtendCoil	:=FALSE;
		Bundling_yPause			:= FALSE;	
		nInitiStep				:= 5;	
	5:
		IF 	Cyl_StackUD.iOriginSensor THEN
			nInitiStep				:= 10;	
		END_IF;
	10:
			strText:='ORG : Done ';
			Initialization	:= TRUE;
	
END_CASE;]]></ST>
      </Implementation>
    </Method>
