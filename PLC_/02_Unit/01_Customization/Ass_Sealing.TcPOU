    <Method Name="Process" Id="{bf7874d8-aa7d-4a83-9850-3952fbf34226}">
      <Declaration><![CDATA[METHOD Process : BOOL
VAR_INPUT
	bHlatMode	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[

_bProcessScan	:= TRUE;
//判斷 

IF _bError THEN
	strText	:= 'OpenBox:Error ';
	strText	:= CONCAT(Status,INT_TO_STRING(nStep));
END_IF;
//半自動模式
IF NOT bHlatMode  THEN
	nStep:= nNextStep;	
END_IF;

_bHaltPause	:= nStep<> nNextStep;
IF _bError OR _bHaltPause THEN
	RETURN;
END_IF

//主程序 
IF NOT _bHaltPause THEN
	CASE nStep OF
		0:
			_tmrT0(IN:=FALSE);
			Motor_BoxSealBottom_L.qRun		:=TRUE;
			Motor_BoxSealBottom_R.qRun		:=TRUE;
			nNextStep						:= 5;
			strText							:= 'Waiting for load';
		5:
			IF Sen_BeltLoadIn THEN
				Cyl_BeltBottomSup.qExtendCoil	:=TRUE;
				strText							:= 'load In';
				nNextStep						:= 10;
			END_IF;	
		10:
			IF NOT Sen_BeltLoadIn THEN
				//Cyl_BeltBottomSup.qExtendCoil	:=FALSE;
				;
			END_IF;		
	
			IF Sen_BeltLoadOut THEN
				Cyl_BeltBottomSup.qExtendCoil	:=FALSE;
				strText						:= 'load Out';
				nNextStep					:= 15;
			END_IF;		
		15:
			_tmrT0(IN:=Sen_BeltLoadOut,PT:=T#0.5S);
			IF _tmrT0.Q THEN
				_tmrT0(IN:=FALSE);
				IF OP.xAutoMode THEN
					nNextStep					:= 20;
					ELSE
					nNextStep					:= 50;
				END_IF;
			END_IF
		20:
				IF M_LoadPic3.Connect= 'Seal In' THEN
					nNextStep					:= 21;
					ELSE
					Motor_BoxSealBottom_L.qRun		:=FALSE;
					Motor_BoxSealBottom_R.qRun		:=FALSE;
				END_IF
		21:
				_tmrT0(IN:=NOT Sen_BeltLoadOut,PT:=T#0.5S);
				Motor_BoxSealBottom_L.qRun		:=TRUE;
				Motor_BoxSealBottom_R.qRun		:=TRUE;		
				IF 	_tmrT0.Q THEN
					_tmrT0(IN:=FALSE);
					nNextStep					:= 50;
				END_IF
		50:
				nNextStep					:= 0;
	END_CASE
END_IF;

Process	:= nStep =50;

]]></ST>
      </Implementation>
    </Method>
