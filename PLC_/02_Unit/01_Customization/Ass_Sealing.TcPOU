<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Ass_Sealing" Id="{25f63225-dbc9-4b1e-b86a-0e068b049cd3}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Ass_Sealing IMPLEMENTS ITF_AutoStructCommand
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	i	:INT;
	_bProcessScan,_bInitialScan: BOOL;
	_bHalt , _bError,_bHaltPause: BOOL;
	strText	:STRING;
	nStep,nInitiStep ,nNextStep 	: INT;
	_tmrT0			:TON;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT _bInitialScan THEN
	nInitiStep	:= 0;
END_IF

_bInitialScan:=FALSE;



IF NOT _bProcessScan THEN
	nNextStep	:= 0;
	nStep		:= 0;
END_IF

_bProcessScan	:=FALSE;]]></ST>
    </Implementation>
    <Property Name="Connect" Id="{83bd3ff5-c6e3-4a8c-8bba-d49023e80782}">
      <Declaration><![CDATA[PROPERTY Connect : STRING(50)
]]></Declaration>
      <Get Name="Get" Id="{5d7475ec-f8cf-40fd-aa0d-db8e368e47ed}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[CASE nStep OF
	5:
	Connect	:= 'OpenBox In';
	20:
	Connect	:= 'Ready'; 
	50:
	Connect	:= 'LoadPic In';
	ELSE	
	Connect	:= '';		
END_CASE]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{927d6ae5-1a73-4a7f-9841-6b22e665c0dd}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[]]></ST>
        </Implementation>
      </Set>
    </Property>
