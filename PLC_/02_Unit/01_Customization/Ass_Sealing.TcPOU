    <Method Name="Initialization" Id="{c0f7d7e1-8a43-4b52-b274-e8f58634f2e0}">
      <Declaration><![CDATA[METHOD Initialization : BOOL
VAR_INPUT
	_Testmode	: BOOL;
END_VAR

VAR
	bConfig: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bInitialScan:=TRUE;

CASE nInitiStep OF
	0:		
		_tmrT0(IN:=FALSE);
		strText:='ORG : Initial ';
		Motor_BoxSealBottom_L.qRun		:=FALSE;
		Motor_BoxSealBottom_R.qRun		:=FALSE;
		Cyl_BeltBottomSup.qExtendCoil	:=FALSE;		
		nInitiStep						:= 5;
	5:
	bConfig			:=TRUE;
	IF Sen_BeltLoadIn OR Sen_BeltLoadOut THEN
		bConfig			:=FALSE;
		EventLogger.eEventType		:= 4;
		EventLogger.strEventText	:= 'Sensor Error ';	
		EventLogger();					
	END_IF		
	IF NOT Motor_BoxSealBottom_R.iError OR NOT Motor_BoxSealBottom_L.iError  THEN
		bConfig			:=FALSE;
		EventLogger.eEventType		:= 4;
		EventLogger.strEventText	:= 'INV. Motor Error ';	
		EventLogger();					
	END_IF	
	
	IF bConfig THEN
		strText:='ORG : Done ';
		nInitiStep	:= 20;
		ELSE
		strText:='ORG : Failed ';
		nInitiStep	:= 50;
	END_IF
	
	
	
	
	

20:
	Initialization	:= TRUE;

END_CASE;]]></ST>
      </Implementation>
    </Method>
