    </Method>
    <Method Name="HaltStepContiune" Id="{c273045f-2497-49da-9d86-8c8a24f4e1cd}">
      <Declaration><![CDATA[METHOD HaltStepContiune : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[nStep:= nNextStep;	]]></ST>
      </Implementation>
    </Method>
    <Method Name="Initialization" Id="{d94725ae-728a-4d23-b958-9e593abe157c}">
      <Declaration><![CDATA[METHOD Initialization : BOOL
VAR_INPUT
	_Testmode	:BOOL;	//OOP Var
END_VAR
VAR
	bConfig: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bInitialScan	:= TRUE;
//初始化部屬 
//	IF Axis_BoxPullOut.Status.Error AND nInitiStep <> 100 THEN
//		nInitiStep:= 99;
//	END_IF
	
CASE nInitiStep OF
	0:
		_tmrT0(IN:=FALSE);
		strText:='ORG : Initial ';
		MC_Home.Execute:=FALSE;
		MC_MoveAbsolute(Axis:= Axis_BoxPullOut,Execute:=FALSE);
			
		Vacm_AxisCatchBox				:=FALSE;
		Cyl_AxisBoxCatch.qExtendCoil	:=FALSE;
		Cyl_Axis90.qExtendCoil			:=FALSE;
		Cyl_AxisBottom.qExtendCoil		:=FALSE;

		Vacm_Axis90						:=FALSE;
		Cyl_BoxSideBottom.qExtendCoil	:=FALSE;
		Cyl_BoxSidePitch.qExtendCoil	:=FALSE;
		
		Cyl_BeltBottom.qExtendCoil		:=FALSE;
		
		IF Cyl_Safe() THEN
			nInitiStep	:= 1;
		END_IF
	1:

	_tmrT0(IN:= NOT _tmrT0.Q ,PT:= T#1S);
	CASE Axis_BoxPullOut.Status.MotionState OF
		MC_AXISSTATE_UNDEFINED:
			;
		MC_AXISSTATE_DISABLED:
			IF Axis_BoxPullOut.Status.Error THEN
				Axis_BoxPullOut.Reset();
				ELSE
				Axis_BoxPullOut.ServoOn();
			END_IF;
		MC_AXISSTATE_STANDSTILL:
			;
		MC_AXISSTATE_ERRORSTOP:
			Axis_BoxPullOut.Reset();
		MC_AXISSTATE_CONTINOUSMOTION:
			Axis_BoxPullOut.Stop();
		MC_AXISSTATE_SYNCHRONIZEDMOTION	:
		;
	END_CASE
	
	IF Axis_BoxPullOut.Status.MotionState =MC_AXISSTATE_STANDSTILL THEN
		_tmrT0(IN:=FALSE);
		nInitiStep	:= 5;
	END_IF
	IF _tmrT0.Q THEN
		_tmrT0(IN:=FALSE);
		nInitiStep	:= 5;		
	END_IF

	5:
		bConfig			:=TRUE;
		IF NOT Axis_BoxPullOut.Status.StandStill THEN
			bConfig			:=FALSE;
			EventLogger.eEventType		:= 4;
			EventLogger.strEventText	:= 'BoxPullOutAxis Error ';	
			EventLogger();					
		END_IF
		
		IF bConfig THEN
			EventLogger.eEventType		:= 2;
			EventLogger.strEventText	:= 'BoxPull ORG Runing ';	
			EventLogger();
			_tmrT0(IN:= FALSE);
			nInitiStep:= nInitiStep + 5 ;
			strText:='ORG : Runing ';
			ELSE
			EventLogger.eEventType		:= 4;
			EventLogger.strEventText	:= 'Exceptions Cause interruptions!! ';	
			EventLogger();
			OP.bInitialSign		:=FALSE;
			OP.xInitialRuning	:=FALSE;
			nInitiStep := nInitiStep +100;	
			strText:='ORG : Failed ';
		END_IF	
		
	10:
		IF NOT Axis_BoxPullOut.Status.Homed THEN
			strText:='ORG : Runing ';
			nInitiStep	:= 16;
			ELSE
			strText:='ORG : Runing ';	
			nInitiStep	:= 17;
		END_IF;	
	//Axis Find Home
	16:
		MC_Home.Execute:=TRUE;
		IF MC_Home.Done THEN
			nInitiStep	:= 17;
		END_IF
		
	
	//Axis Go Abs SDANDBY Pos
	17:
		MC_MoveAbsolute(Axis:= Axis_BoxPullOut,Execute:=TRUE,Position:= RunParameter.Unboxing_PullOut,Velocity:= RunParameter.Unboxing_Velo);
			
		IF MC_MoveAbsolute.Done THEN
			MC_Home(Axis:= Axis_BoxPullOut,Execute:=FALSE);
			MC_MoveAbsolute(Axis:= Axis_BoxPullOut,Execute:=FALSE);	
			nInitiStep	:= 20;
		END_IF	
		
		
		
	//JobDone		
	20:
		strText:='ORG : Done ';
		Initialization	:= TRUE;	
	//Error step
	99:	
		IF Axis_BoxPullOut.DeviceErrorcode <> 0  THEN
			EventLogger.eEventType	:= E_EventType.Error;
			EventLogger.strEventText:= 'UnboxServo Driver Error';
			EventLogger.strEventText:= CONCAT(EventLogger.strEventText,WORD_TO_STRING(Axis_BoxPullOut.DeviceErrorcode));
			EventLogger();
		END_IF
		
		nInitiStep	:= 100;
END_CASE


]]></ST>
      </Implementation>
    </Method>
    <Property Name="NoEntry" Id="{befa025c-d2f0-40e8-9b59-96ee3d462de7}">
      <Declaration><![CDATA[{warning 'add property implementation'}
