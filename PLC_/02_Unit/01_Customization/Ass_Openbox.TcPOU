    <Method Name="Cyl_Safe" Id="{7dd6f484-6ef4-4250-8a57-ff6fe0135fe9}">
      <Declaration><![CDATA[METHOD INTERNAL Cyl_Safe : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Cyl_Safe	:= Cyl_AxisBoxCatch.iOriginSensor AND Cyl_Axis90.iOriginSensor AND
				Cyl_AxisBottom.iOriginSensor AND Cyl_BoxSideBottom.iOriginSensor AND 	
				Cyl_BoxSidePitch.iOriginSensor	AND Cyl_BeltBottom.iOriginSensor ;
]]></ST>
      </Implementation>
    </Method>
