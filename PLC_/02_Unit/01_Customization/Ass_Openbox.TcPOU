    <Method Name="Pause" Id="{ba2412fb-0b39-4975-9760-48b5002ca4b2}">
      <Declaration><![CDATA[{warning 'add method implementation '}
METHOD Pause : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="Process" Id="{c66cbcd7-edc7-4b8f-8855-86abcab135c8}">
      <Declaration><![CDATA[METHOD Process : BOOL		//OOP Return
VAR_INPUT
	bHlatMode	: BOOL;		//OOP Var
END_VAR
VAR
	_strTemp	:STRING[50];
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bProcessScan	:= TRUE;
//判斷 

IF _bError THEN
	strText	:= 'OpenBox:Error ';
	strText	:= CONCAT(Status,INT_TO_STRING(nStep));
END_IF;
//半自動模式
IF NOT bHlatMode  THEN
	nStep:= nNextStep;	
END_IF;

_bHaltPause	:= nStep<> nNextStep;
IF _bError OR _bHaltPause THEN
	RETURN;
END_IF

//主程序 
IF NOT _bHaltPause THEN
	tmrloadIn(in:= NOT tmrloadIn.q , PT:=RunParameter.Unboxing_DelayTime[0]);	
	IF tmrloadIn.Q THEN
		IF NOT Sen_BoxsideFeed THEN
			wPunchcounter	:= 	wPunchcounter + 1 ;
			Cyl_BoxSidePitch.qExtendCoil:= TRUE;
			ELSE
			wPunchcounter	:= 0;			
		END_IF
	END_IF;
	tmrloadIn2(IN:= Cyl_BoxSidePitch.iEndSensor ,PT:= T#1S);
	IF tmrloadIn2.q THEN
		Cyl_BoxSidePitch.qExtendCoil:= FALSE;			
	END_IF
	
	
	CASE nStep OF
		0:
			tmrDelay(IN:=FALSE);
			MC_MoveAbsolute(Axis:=Axis_BoxPullOut,Execute:=FALSE);
			IF Axis_BoxPullOut.Status.MotionState= MC_AXISSTATE_STANDSTILL AND Axis_BoxPullOut.Status.Homed THEN
				strText:= '';
				nNextStep	:= 10;
				nStep		:= 10;
				ELSE
				nNextStep	:= 100;
				nStep		:= 100;	
				strText:= '馬達狀態異常 ';			
			END_IF;
			
		10:
			MC_MoveAbsolute(Axis:= Axis_BoxPullOut,Execute:=TRUE,Position:= RunParameter.Unboxing_PullOut,Velocity:= RunParameter.Unboxing_Velo);
			IF MC_MoveAbsolute.Done THEN
				MC_MoveAbsolute(Axis:=Axis_BoxPullOut,Execute:=FALSE);
				nNextStep	:= 15;
			END_IF	
		15:
			Cyl_AxisBoxCatch.qExtendCoil	:= TRUE;
			IF Cyl_AxisBoxCatch.iEndSensor THEN
				nNextStep	:= 20;
			END_IF
		20:
			Vacm_AxisCatchBox:= TRUE;
			IF Sen_AxisBoxCatchVacumm THEN
				nNextStep	:= 21;
			END_IF
		21:
			Cyl_AxisBoxCatch.qExtendCoil	:= FALSE;	
			IF Cyl_AxisBoxCatch.iOriginSensor THEN
				nNextStep	:= 22;
			END_IF			
		22:
			Cyl_Axis90.qExtendCoil	:= TRUE;	
			tmrDelay(IN:= Cyl_Axis90.iEndSensor , pt:= T#1S);
			IF Cyl_Axis90.iEndSensor THEN
				tmrDelay(IN:=FALSE);
				nNextStep	:= 23;
			END_IF
		23:		
			Vacm_Axis90				:= TRUE;
			IF Sen_Axis90Vacumm THEN
				nNextStep	:= 24;
			END_IF
		24:
			Cyl_AxisBottom.qExtendCoil	:= TRUE;
			IF Cyl_AxisBottom.iEndSensor THEN
				nNextStep	:= 25;
			END_IF

		25:
			MC_MoveAbsolute(Axis:= Axis_BoxPullOut,Execute:=TRUE,Position:= RunParameter.Unboxing_PullOut+60,Velocity:= RunParameter.Unboxing_Velo);


			IF MC_MoveAbsolute.Done THEN
				MC_MoveAbsolute(Axis:=Axis_BoxPullOut,Execute:=FALSE);
				nNextStep	:= 26;
			END_IF
		26:
			Cyl_BeltBottom.qExtendCoil	:= TRUE;
			IF  Cyl_BeltBottom.iEndSensor THEN
				nNextStep	:= 27;
			END_IF		

		27:
			Cyl_BoxSideBottom.qExtendCoil	:= TRUE;
			IF Cyl_BoxSideBottom.iEndSensor THEN
				nNextStep	:= 28;
			END_IF

		28:
			tmrDelay(IN:=FALSE);
			strText:= 'Wait for Next St. ';	

			IF M_Sealing2.Connect = 'OpenBox In' THEN
				nNextStep	:= 30;
			END_IF
			
			IF NOT OP.xAutoMode THEN
				nNextStep	:= 30;
			END_IF
	
		30:
			MC_MoveAbsolute(Axis:= Axis_BoxPullOut,Execute:=TRUE,Position:= RunParameter.Unboxing_LoadOut,Velocity:= RunParameter.Unboxing_Velo);

		IF Sen_BeltLoadIn THEN
				Cyl_BeltBottom.qExtendCoil		:= TRUE;
				Cyl_BoxSideBottom.qExtendCoil	:= FALSE;
				Vacm_AxisCatchBox				:=FALSE;
				//Cyl_AxisBottom.qExtendCoil		:= FALSE;
				Cyl_BeltBottom.qExtendCoil		:= FALSE;
				//Cyl_Axis90.qExtendCoil			:= FALSE;	
				Vacm_Axis90						:= FALSE;
			END_IF
			tmrDelay(IN:=MC_MoveAbsolute.Done,PT:=T#2S);
			IF tmrDelay.Q  THEN
				Cyl_BoxSideBottom.qExtendCoil	:= FALSE;
				Vacm_AxisCatchBox			:=FALSE;
				Cyl_AxisBottom.qExtendCoil	:= FALSE;
				Cyl_AxisBottom.qExtendCoil	:= FALSE;
				Cyl_BeltBottom.qExtendCoil	:= FALSE;
				Cyl_Axis90.qExtendCoil	:= FALSE;	
				Vacm_Axis90				:= FALSE;
				MC_MoveAbsolute(Axis:=Axis_BoxPullOut,Execute:=FALSE);
				nNextStep	:= 50;
			END_IF		

	

		50:
			IF OP.xAutoMode THEN
				nNextStep	:= 0;
			END_IF
			;
	END_CASE
END_IF;

Process	:= nStep =50;
]]></ST>
      </Implementation>
    </Method>
