<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Ass_Openbox" Id="{6fbfd320-f751-4f5c-aa0c-b173d550b2ff}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Ass_Openbox IMPLEMENTS ITF_AutoStructCommand
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	strText	:STRING;
	i	:INT;
	MC_MoveAbsolute		: MC_MoveAbsolute;
	MC_Home				: MC_Home;
	_bProcessScan,_bInitialScan: BOOL;
	_bHalt , _bError,_bHaltPause: BOOL;
	nStep,nStt,nInitiStep	: INT;
	nNextStep		: INT;
	tmrClear		:TON;
	temp: DWORD;
	tmrloadIn,tmrloadIn2,tmrDelay: TON;
	wPunchcounter	:INT;
	_tmrT0: TON;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[MC_Home(Axis:= Axis_BoxPullOut,bCalibrationCam := NOT Sen_AxisBoxORG);

IF NOT _bInitialScan THEN
	nInitiStep	:= 0;
END_IF

_bInitialScan:=FALSE;



IF NOT _bProcessScan THEN
	nNextStep	:= 0;
	nStep		:= 0;
END_IF

_bProcessScan	:=FALSE;]]></ST>
    </Implementation>
