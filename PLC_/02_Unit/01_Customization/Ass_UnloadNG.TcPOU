    <Method Name="Pause" Id="{a877b4d4-c843-4482-9061-6c3f8d9f1f13}">
      <Declaration><![CDATA[{warning 'add method implementation '}
METHOD Pause : BOOL
]]></Declaration>
      <Implementation>
