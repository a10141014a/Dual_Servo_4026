<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Ass_UnloadNG" Id="{bd20b21e-c1a4-4f4a-a1c0-5aa3b9f16856}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Ass_UnloadNG IMPLEMENTS ITF_AutoStructCommand
VAR_INPUT
END_VAR
VAR_OUTPUT
	SamplingWeight	:REAL;
END_VAR
VAR
	strText,strNGText,strShackText 	:STRING;
	i	:INT;
	_bProcessScan,_bInitialScan: BOOL;
	_bHalt , _bError,_bHaltPause: BOOL;
	nStep,nInitiStep ,nNGStep,nShackStep 	: INT;
	_tmrT0,tmrLoadcell,tmrshock	,tmrNG		:TON;
	bBoxPass: BOOL;
	tmrClear: TON;
	UpperWeight,LowerWeight	:REAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT _bInitialScan AND NOT _bProcessScan THEN
	strText:=strNGText:=strShackText	:='';
END_IF


IF NOT _bInitialScan THEN
	nInitiStep	:= 0;
END_IF

_bInitialScan:=FALSE;



IF NOT _bProcessScan THEN
	nShackStep	:= 0;
	nNGStep		:= 0;
	nStep		:= 0;
END_IF

_bProcessScan	:=FALSE;

]]></ST>
    </Implementation>
