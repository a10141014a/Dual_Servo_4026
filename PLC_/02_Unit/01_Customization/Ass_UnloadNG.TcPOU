    <Method Name="Initialization" Id="{590597e0-2263-4555-812b-e1b41a0161a3}">
      <Declaration><![CDATA[METHOD Initialization : BOOL
VAR_INPUT
	_Testmode	: BOOL;
END_VAR

VAR
	bConfig: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*
_tmrT0(IN:=TRUE,PT:=T#0.2S);
LoadCell.i_bCmd_Tara:= NOT _tmrT0.Q  ;
Initialization	:= AssRoller.Initialization() AND _tmrT0.Q ;
SamplingWeight	:=0;
Cyl_NGPurge.qExtendCoil	:= FALSE;
Roller_Purge.qRun:= FALSE;
Motor_shock.qRun	:= FALSE;
Motor_shock.qSign	:= FALSE;
Cyl_ShockStop.qExtendCoil:= FALSE;
*)

_bInitialScan:=TRUE;

CASE nInitiStep OF
	0:		
		LoadCell.GetTara();
		_tmrT0(IN:=FALSE);
		strText:='ORG : Initial ';
		Cyl_NGPurge.qExtendCoil		:= FALSE;
		Roller_Purge.qRun			:= FALSE;
		Motor_shock.qRun			:= FALSE;
		Motor_shock.qSign			:= FALSE;
		Cyl_ShockStop.qExtendCoil	:= FALSE;		
		nInitiStep						:= 5;
	5:
		bConfig			:=TRUE;
		IF Sen_TFLoadIn THEN
			bConfig			:=FALSE;
			EventLogger.eEventType		:= 3;
			EventLogger.strEventText	:= 'TF Sensor Error ';	
			EventLogger();					
		END_IF		
			
		IF bConfig THEN
			nInitiStep	:= 10;
			strText:='ORG : Runing ';
			ELSE
			strText:='ORG : Failed ';
			nInitiStep	:= 50;
		END_IF	
	10:
		IF AssRoller.Initialization() THEN
			strText		:='ORG : Done ';
			nInitiStep	:= 20;
		END_IF;		
	20:
		Initialization	:= TRUE;
	
END_CASE;
	]]></ST>
      </Implementation>
    </Method>
