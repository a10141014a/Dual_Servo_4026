      </Implementation>
    </Method>
    <Method Name="Process" Id="{30f199c4-bbb5-40fe-ab57-f5f98610f032}">
      <Declaration><![CDATA[METHOD Process : BOOL
VAR_INPUT
	bHlatMode	: BOOL;
END_VAR

VAR
	bStoppedComv: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bProcessScan:= TRUE;
//判斷 

CASE nStep OF
	0:
		tmrLoadcell(IN:= FALSE);
		_tmrT0(IN:=FALSE);
		AssRoller.Roller();
		strText:= 'Waiting';
		IF Sen_TFLoadIn THEN
			nStep := 5;
		END_IF
	5:
		strText:= 'Loadind and Stop';
		AssRoller.Roller();
		IF NOT Sen_TFLoadIn THEN
			SamplingWeight	:= 0;
			nStep := 10;
		END_IF	
	10:		
		strText:= 'Weight Check!';
		tmrLoadcell(IN:= TRUE,PT:=T#1S);
		UpperWeight	:= RunParameter.PackagingWeight + RunParameter.PackagingWeightUpLimit ;
		LowerWeight := RunParameter.PackagingWeight - RunParameter.PackagingWeightLowLimit ;
		IF tmrLoadcell.Q THEN
			tmrLoadcell(IN:= FALSE,PT:=T#1S);
			SamplingWeight	:= 	LoadCell.o_rWeight;
			IF SamplingWeight >= LowerWeight AND
				SamplingWeight <= UpperWeight THEN
				strText:= 'Weight Pass!';
				bBoxPass:= TRUE;
				ELSE
				EventLogger.eEventType		:= 2;
				EventLogger.strEventText	:= 'Box Over Weight ';	
				EventLogger.strEventText	:=	CONCAT(EventLogger.strEventText,LEFT(REAL_TO_STRING(SamplingWeight),3));
				EventLogger();
				strText:= 'Box NG';
				bBoxPass:= FALSE;
			END_IF
			nStep := 15;
		END_IF
	
	15:
		
		IF nNGstep = 0 THEN
			nNGstep	:= 5;
			IF RunParameter.PackagingCheck THEN
				bStoppedComv	:= TRUE;
			END_IF
			AssRoller.Belt();
			IF Sen_NGLoadOut THEN
				nStep := 0;
			END_IF;
		END_IF
		
		
		
		
END_CASE;

CASE nNGstep OF
	0:
		strNGText	:= 'Wait BOX';
		tmrNG(IN:=FALSE,PT:=T#2S);
		Roller_Purge.qRun:= TRUE;
		IF Sen_NGLoadOut THEN
			strNGText	:= 'Active Loading';
			nNGstep := 20;
			CASE nStep OF
				0..10:
				strNGText	:= 'Up Loading';
				nNGstep := 50;
			END_CASE
		END_IF
	5:
		strNGText	:= 'TF Loading';
		AssRoller.Belt();
	
		IF Sen_NGLoadOut THEN
			nStep := 0;
			nNGstep	:= 6;
		END_IF
	6:
			IF bBoxPass THEN
				strNGText	:= 'TF LoadIn Stop';
				Roller_Purge.qRun:= FALSE;
				nStep := 0;
				IF nShackStep = 1 THEN
					strNGText	:= 'Go Shack';
					Roller_Purge.qRun:= TRUE;
					nNGstep	:= 10;
				END_IF;
				ELSE
				EventLogger.eEventType		:= 2;
				EventLogger.strEventText	:= 'NG Perge!';		
				EventLogger();		
				strNGText	:= 'TF NG Perge';
				nNGstep	:= 30;
				Roller_Purge.qRun:= FALSE;
			END_IF		

		
	10:
		IF Sen_ShockPos THEN
			strNGText	:= 'Shack ORG';
			nNGstep	:= 0;
		END_IF
	
	
	30://重量Error
		Cyl_NGPurge.qExtendCoil	:= TRUE;
		tmrNG(IN:=TRUE,PT:=T#2S);
		IF tmrNG.Q THEN
			tmrNG(IN:=FALSE);
			nStep := 0;
			Cyl_NGPurge.qExtendCoil	:= FALSE;
			nNGstep := 0;
		END_IF		
		
		
		
	50://手動投入	
		strNGText	:= '50 Man. ';
		IF Sen_ShockPos THEN
			nNGstep	:= 0;
		END_IF	
END_CASE;	
CASE nShackStep OF
	0:
		tmrshock(IN:=FALSE);
		nShackStep	:= 1;
	1:
		strShackText:='Wait Box';
		Cyl_ShockStop.qExtendCoil:= TRUE;
		tmrshock(IN:=Sen_ShockPos , PT:= RunParameter.shock_DelayTime);	
		Motor_shock.qRun	:= TRUE;
		Motor_shock.qSign	:= TRUE;
		IF tmrshock.q THEN
			strShackText:='Loading Box';
			tmrshock(IN:=FALSE);
			nShackStep	:= 5;
		END_IF
	5:
		strShackText:='Shack Box';
		Motor_shock.qSign	:= FALSE;
		tmrshock(IN:= TRUE, PT:= RunParameter.shock_HighTime);
		IF tmrshock.Q THEN
			tmrshock(IN:= FALSE);
			Motor_shock.qSign	:= TRUE;
			Cyl_ShockStop.qExtendCoil:= FALSE;
			nShackStep	:= 10;
		END_IF
	10:
		strShackText:='Load Out Box';
		tmrshock(IN:= NOT Sen_ShockPos , PT:= T#3S);				

		IF tmrshock.Q THEN
			Cyl_ShockStop.qExtendCoil:= TRUE;
			tmrshock(IN:= FALSE);
			nShackStep	:= 0;
		END_IF
		
		
END_CASE;		
	
		]]></ST>
      </Implementation>
    </Method>
    <Property Name="Status" Id="{54765cf9-d21f-45b1-92d3-fce37714c6cc}">
