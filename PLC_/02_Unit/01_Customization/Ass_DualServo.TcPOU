<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="Ass_DualServo" Id="{29cca747-7da9-4f26-a5ee-de90be653942}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Ass_DualServo IMPLEMENTS ITF_AutoStructCommand
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	strText,strLeftText,strRightText	:STRING;
	tmrAuto	:TON:= (PT := TIME#1S0MS);
	bConfig	,_bError	:BOOL;
	_tmrT0		: TON;
	nInitiStep,nStopStep: INT;
	fb1_Stop,fb2_Stop,fbFly_Stop		:MC_Stop;
	fb1_Reset,fb2_Reset,fbFly_Reset		:MC_Reset;
	fbMC_MoveVelocityDaul: MC_MoveVelocity := (Velocity := 500);
	fbMC_GearIn: MC_GearIn;
	fbMC_GearOut: MC_GearOut;
	bDual1First,bDual2First,bDual1Done,bDual2Done	:BOOL;	
	MC_SetPositionLeft,MC_SetPositionRight,MC_SetPositionCon:MC_SetPosition;
	PreDual1Pos,PreDual2Pos	:  LREAL;
	L_Home,R_Home:MC_Home := (HomingMode := MC_HOMINGMODE.MC_ForceCalibration);
	MC_GroupReset: MC_GroupReset;
	LatchDual1Pos,LatchDual2Pos: LREAL;
	fbMC_MoveModule1,fbMC_MoveModule2	:MC_MoveModulo := (Velocity := 500);
	ConvQty	:INT;
	_bInitialScan	:BOOL;
	
	//Group
	fbMC_UngroupAllAxes	: MC_UngroupAllAxes;
	fbMC_GroupDisable	: MC_GroupDisable;
	fbAddAxis			: ARRAY[1..2] OF MC_AddAxisToGroup;
	fbMC_GroupEnable	: MC_GroupEnable;	
	fbMC_MoveAbsoluteCA_Left,fbMC_MoveAbsoluteCA_Right: MC_MoveAbsoluteCA := (Options := (GapControlMode := MC_GAP_CONTROL_MODE.mcGapControlModeFast));
	fbMC_GearInPosCA_Left,fbMC_GearInPosCA_Right		:MC_GearInPosCA;	
	nStep,nLeftStep,nRightStep,i	:INT;
	LeftLoadinQty,RifgtLoadinQty: UINT;
	bHMITriggerBtn: BOOL;
	fbMC_StopFly		:MC_Stop;
	MC_TouchProbeDual1,MC_TouchProbeDual2,MC_TouchProbeFly: MC_TouchProbe;
	TouchTriggerDual1,TouchTriggerDual2,TouchTriggerFly	:TRIGGER_REF;
	MC_AbortTrigger1,MC_AbortTrigger2					: MC_AbortTrigger;
	tmrT0,tmrT1	:TON := (ET := TIME#2S0MS);
	tmrFlyinDef	:TON;
	bPosfix	:BOOL;
	_bProcessScan: BOOL;
	_Dual1CalibrationPos , _Dual2CalibrationPos,_FlyInCalibrationPos	:LREAL;
	//
	fbSensorTrigger	:R_TRIG;
	dwSenesorTriggerTimes	:DWORD;
	
	wSlot: INT;
	bPause: BOOL;
	fRampTime: REAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[Instance();
fbSensorTrigger(CLK:=Axis_FlyIn.DI.19);
IF fbSensorTrigger.Q THEN
	dwSenesorTriggerTimes	:= dwSenesorTriggerTimes+1;
END_IF



//Modhed
IF NOT _bProcessScan AND NOT _bInitialScan THEN
	strText:=strLeftText:=strRightText:='';
END_IF


IF NOT _bInitialScan THEN
	nInitiStep	:= 0;
END_IF

_bInitialScan:=FALSE;



IF NOT _bProcessScan THEN
	nStep	:= 0;
	nLeftStep	:=0;
	nRightStep	:=0;
END_IF


_bProcessScan:=FALSE;]]></ST>
    </Implementation>
    <Method Name="_Clearfb" Id="{598a0349-536b-4a20-8dd2-78f75dd933ad}">
      <Declaration><![CDATA[METHOD _Clearfb : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbAddAxis[1](AxesGroup:=DualGroupRef, Axis := Axis_DualServo1, Execute := FALSE);
fbAddAxis[2](AxesGroup:=DualGroupRef, Axis := Axis_DualServo2, Execute := FALSE);
fbMC_MoveVelocityDaul(Axis:= Axis_DualServo1,Execute:= FALSE);
fbMC_GroupEnable(AxesGroup:= DualGroupRef, Execute:= FALSE);
fbMC_GroupDisable(AxesGroup:= DualGroupRef, Execute:= FALSE);	
fbMC_UngroupAllAxes(AxesGroup:= DualGroupRef,Execute:= FALSE);
fbMC_MoveAbsoluteCA_Left(Axis:= Axis_DualServo1,Execute:=FALSE);
fbMC_MoveAbsoluteCA_Right(Axis:= Axis_DualServo1,Execute:=FALSE);
_tmrT0(IN:=FALSE);
nInitiStep:=0;
nStep	:=0;
nLeftStep	:=0;
nRightStep	:=0;
		MC_AbortTrigger1(Axis:= Axis_DualServo1,TriggerInput:= TouchTriggerDual1,Execute:= FALSE);
		MC_AbortTrigger2(Axis:= Axis_DualServo2, TriggerInput:= TouchTriggerDual2,	Execute:= FALSE);
		MC_TouchProbeDual1(	Axis:= Axis_DualServo1,TriggerInput:=TouchTriggerDual1,Execute:= FALSE); 
		MC_TouchProbeDual2(	Axis:= Axis_DualServo2,TriggerInput:=TouchTriggerDual2,Execute:= FALSE); 
		
fbMC_MoveAbsoluteCA_Left(Axis:= Axis_DualServo1,Execute:=FALSE,Position:=RunParameter.Dual_LoadInPos,Velocity:=RunParameter.Dual_Velo,Gap:= RunParameter.Dual_Gap + (RunParameter.Dual_Length));
fbMC_MoveAbsoluteCA_Right(Axis:= Axis_DualServo2,Execute:=FALSE,Position:=RunParameter.Dual_LoadInPos,Velocity:=RunParameter.Dual_Velo,Gap:=fbMC_MoveAbsoluteCA_Left.Gap);
]]></ST>
      </Implementation>
    </Method>
