	clear	:ST_SlotData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[FOR i :=  1TO 5 DO
	slot[i]	:= clear	;
END_FOR;
ConvQty	:= 0;]]></ST>
      </Implementation>
    </Method>
