      <Declaration><![CDATA[METHOD ErrorClear : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bError	:= FALSE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{3c67647f-4069-4f92-affe-311c7be04a50}">
      <Declaration><![CDATA[{warning 'add method implementation '}
METHOD FB_init : BOOL
VAR_INPUT
	(* if TRUE, the retain variables are initialized (warm start / cold start)*)
	bInitRetains	: BOOL;
	(* if TRUE, the instance afterwards gets moved into the copy code (online change)*)
	bInCopyCode	: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="HaltStepContiune" Id="{ef121d40-ba23-4ebf-abc0-02af33e485ba}">
      <Declaration><![CDATA[{warning 'add method implementation '}
METHOD HaltStepContiune : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="Initialization" Id="{105550df-bf40-45a4-afe8-08ca51d11f31}">
      <Declaration><![CDATA[METHOD Initialization : BOOL
VAR_INPUT
	_Testmode	:BOOL;
END_VAR
VAR
	bConfig: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bInitialScan	:= TRUE;

CASE nInitiStep OF
	0:
		RB_CS_PickIO.cmd_bBoxInPos	:=FALSE;
		fbMC_AbsLoad1(Axis:= Axis_load1,Velocity:= 100,Execute:= FALSE);
		fbMC_AbsLoad2(Axis:= Axis_load2,Velocity:= 100,Execute:= FALSE);
		fbHomeInside.Execute:=FALSE;
		fbHomeOutside.Execute:=FALSE;
		fbMC_GearOut(Slave:= Axis_load2,Execute:=FALSE);
		_tmrT0(IN:=FALSE);
		Cyl_UnloadDef.qExtendCoil	:= FALSE;
		strText:='ORG : Initial ';
		IF AssRoller.Initialization() THEN
			nInitiStep := 1;
		END_IF
	1:
		_tmrT0(IN:= NOT _tmrT0.Q ,PT:= T#1S);
		CASE Axis_load1.Status.MotionState OF
			MC_AXISSTATE_DISABLED:
			 	Axis_load1.ServoOn();
			MC_AXISSTATE_ERRORSTOP:
				Axis_load1.Reset();
			MC_AXISSTATE_STOPPING:
				Axis_load1.Stop();
			MC_AXISSTATE_SYNCHRONIZEDMOTION:
			;
		END_CASE;		
		CASE Axis_load2.Status.MotionState OF
			MC_AXISSTATE_DISABLED:
			 	Axis_load2.ServoOn();
			MC_AXISSTATE_ERRORSTOP:
				Axis_load2.Reset();
			MC_AXISSTATE_STOPPING:
				Axis_load2.Stop();
			MC_AXISSTATE_SYNCHRONIZEDMOTION:
				fbMC_GearOut(Slave:= Axis_load2,Execute:=TRUE);
		END_CASE;			
		
		IF  Axis_load1.Status.MotionState=MC_AXISSTATE_STANDSTILL AND Axis_load2.Status.MotionState=MC_AXISSTATE_STANDSTILL THEN
			_tmrT0(IN:=FALSE);
			nInitiStep	:=5 ;
		END_IF
		IF _tmrT0.Q THEN
			_tmrT0(IN:=FALSE);
			nInitiStep	:= 5;		
		END_IF
	5:
		bConfig			:=TRUE;
		IF NOT Axis_load1.Status.StandStill THEN
			bConfig			:=FALSE;
			EventLogger.eEventType		:= 4;
			EventLogger.strEventText	:= 'RightAxis Error ';	
			EventLogger();					
		END_IF
		IF NOT Axis_load2.Status.StandStill THEN
			bConfig			:=FALSE;
			EventLogger.eEventType		:= 4;
			EventLogger.strEventText	:= 'LefthtAxis Error';	
			EventLogger();					
		END_IF
		
		IF bConfig THEN
			IF NOT OP.xAutoMode THEN
				EventLogger.eEventType		:= 2;
				EventLogger.strEventText	:= 'LoadIn servo ORG Runing ';	
				EventLogger();
			END_IF;
			_tmrT0(IN:= FALSE);
			nInitiStep:= 10 ;
			strText:='ORG : Runing ';
			ELSE
			EventLogger.eEventType		:= 4;
			EventLogger.strEventText	:= 'Exceptions Cause interruptions!! ';	
			EventLogger();
			OP.xAutoRuning	:=FALSE;
			nInitiStep := nInitiStep +100;	
			strText:='ORG : Failed  ';
		END_IF			
		
	10:
		fbHomeInside.Execute:=TRUE;
		fbHomeOutside.Execute:=TRUE;
		fbMC_AbsLoad1(Axis:= Axis_load1,Position:= 0,Velocity:= RunParameter.Load_Velo,Execute:= fbHomeInside.Done );
		fbMC_AbsLoad2(Axis:= Axis_load2,Position:= 0,Velocity:= RunParameter.Load_Velo,Execute:=  fbHomeOutside.Done);
	
		IF fbMC_AbsLoad1.Done AND fbMC_AbsLoad2.Done THEN
			fbHomeInside.Execute:=FALSE;
			fbHomeOutside.Execute:=FALSE;
			fbMC_AbsLoad1(Axis:= Axis_load1,Velocity:= RunParameter.Load_Velo,Execute:=FALSE );
			fbMC_AbsLoad2(Axis:= Axis_load2,Velocity:= RunParameter.Load_Velo,Execute:=FALSE );
			strText:='ORG : Done ';
			nInitiStep	:= 20 ;
		END_IF
	20:
		Initialization := TRUE;

END_CASE;]]></ST>
      </Implementation>
    </Method>
    <Property Name="NoEntry" Id="{8ec65748-586b-4750-9ce0-856e1544908c}">
      <Declaration><![CDATA[{warning 'add property implementation'}
PROPERTY NoEntry : BOOL
]]></Declaration>
      <Get Name="Get" Id="{11ed35a8-a5c5-40d1-8ef2-a6a43ee5c9d3}">
        <Declaration><![CDATA[VAR
END_VAR
