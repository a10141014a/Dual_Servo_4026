<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Ass_LoadPic" Id="{41058aa1-f0d8-4eea-8392-b9cb2c6e1dc2}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Ass_LoadPic IMPLEMENTS ITF_AutoStructCommand
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	strText	:STRING;
	i	:INT;
	_bProcessScan,_bInitialScan		: BOOL;
	_bHalt , _bError,_bHaltPause	: BOOL;
	nStep,nInitiStep ,nNextStep 	: INT;
	fbHomeInside,fbHomeOutside		:MC_Home	;
	fbMC_GearIn						: MC_GearIn;
	fbMC_GearOut					: MC_GearOut;
	fbMC_AbsLoad1,fbMC_AbsLoad2		:MC_MoveAbsolute;
	_tmrT0							: TON;
	temp:DWORD;
	bReady: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT _bInitialScan AND NOT _bProcessScan  THEN
	fbHomeInside.Execute:=FALSE;
	fbHomeOutside.Execute:=FALSE;
END_IF


IF NOT _bInitialScan THEN
	nInitiStep	:= 0;
END_IF

_bInitialScan:=FALSE;



IF NOT _bProcessScan THEN
	nNextStep	:= 0;
	nStep		:= 0;
END_IF

_bProcessScan	:=FALSE;






fbHomeInside(Axis:= Axis_load1,Position:= Setting_Unload1_ORG_Offset*-1,bCalibrationCam:= NOT Sen_AxisLoad1ORG);
fbHomeOutside(Axis:= Axis_load2,Position:= Setting_Unload2_ORG_Offset*-1,bCalibrationCam:= NOT Sen_AxisLoad2ORG);]]></ST>
    </Implementation>
    <Method Name="_Clearfb" Id="{aad993d0-491f-4baf-a2f6-4ec83f321454}">
      <Declaration><![CDATA[METHOD _Clearfb : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[	fbMC_GearIn(Master:=Axis_load1,Slave:=Axis_load2,Execute:=FALSE);
	fbMC_GearOut(Slave:=Axis_load2,Execute:=FALSE);
	fbHomeInside(Axis:= Axis_load1,bCalibrationCam:= FALSE,Execute:=FALSE);
	fbHomeOutside(Axis:= Axis_load2,bCalibrationCam:= FALSE,Execute:=FALSE);
	_tmrT0(IN:=FALSE);
	nInitiStep:=0;]]></ST>
      </Implementation>
    </Method>
    <Property Name="Connect" Id="{dd733115-1bb2-4f8e-bc53-dbef49f5e4af}">
      <Declaration><![CDATA[{warning 'add property implementation'}
PROPERTY Connect : STRING(50)
]]></Declaration>
      <Get Name="Get" Id="{019cfa34-437d-40b0-9773-6999e0db6284}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[CASE nStep OF
 10:
	Connect	:= 'Seal In';
20:
	Connect	:= 'LoadIng';
 25:
	Connect	:= 'Seal In';	
	ELSE	
	Connect	:= '';		
END_CASE]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{e35af6d6-9509-4a31-8e28-168b58415986}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[]]></ST>
        </Implementation>
      </Set>
    </Property>
